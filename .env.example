# RedThread Environment Configuration
# Copy this file to .env and fill in your values

# ── Target LLM (the model being attacked) ────────────────────────────────────
REDTHREAD_TARGET_BACKEND=ollama          # ollama | openai | llama_cpp
REDTHREAD_TARGET_MODEL=gemma4:e4b      # Ollama model name or OpenAI model ID
REDTHREAD_TARGET_BASE_URL=http://localhost:11434
REDTHREAD_LLAMA_CPP_BASE_URL=http://localhost:8080

# ── Attacker LLM (generates adversarial prompts) ────────────────────────────
# DeepHat (WhiteRabbitNeo): uncensored cybersecurity model optimized for red-teaming
REDTHREAD_ATTACKER_BACKEND=ollama
REDTHREAD_ATTACKER_MODEL=DeepHat/DeepHat-V1-7B
REDTHREAD_ATTACKER_BASE_URL=http://localhost:11434

# ── Judge LLM (evaluates attack results — heavyweight, GPT-4o) ──────────────
# The entire self-healing loop depends on judge accuracy. Keep as GPT-4o.
REDTHREAD_JUDGE_BACKEND=openai
REDTHREAD_JUDGE_MODEL=gpt-4o
REDTHREAD_OPENAI_API_KEY=sk-...your-key-here...

# ── Defense Architect (synthesizes guardrails — high-fidelity, grounded) ──────
# Anti-Hallucination SOP: Decoupled from Attacker. Uses frontier model.
REDTHREAD_DEFENSE_ARCHITECT_BACKEND=openai
REDTHREAD_DEFENSE_ARCHITECT_MODEL=gpt-4o

# ── Per-Role Temperature Control (Anti-Hallucination SOP) ────────────────────
REDTHREAD_ATTACKER_TEMPERATURE=0.8     # High: creative adversarial diversity
REDTHREAD_JUDGE_TEMPERATURE=0.0        # Zero: deterministic, reproducible eval
REDTHREAD_DEFENSE_ARCHITECT_TEMPERATURE=0.1  # Near-zero: grounded guardrails

# ── Algorithm Configuration ──────────────────────────────────────────────────
REDTHREAD_ALGORITHM=pair                # pair | tap | crescendo | mcts
REDTHREAD_MAX_ITERATIONS=20
REDTHREAD_SUCCESS_THRESHOLD=4.5        # G-Eval score [1-5] to confirm jailbreak

# ── Logging ──────────────────────────────────────────────────────────────────
REDTHREAD_LOG_DIR=./logs
REDTHREAD_MEMORY_DIR=./memory
REDTHREAD_VERBOSE=false
REDTHREAD_DRY_RUN=false

# ── Telemetry & ASI (Phase 5B — Vital Signs) ─────────────────────────────────
REDTHREAD_TELEMETRY_ENABLED=true
REDTHREAD_ASI_WINDOW_SIZE=50
REDTHREAD_ARIMA_CONFIDENCE_LEVEL=0.95
REDTHREAD_ASI_ALERT_THRESHOLD=60.0

# ── Security Guard Daemon (Phase 5C) ─────────────────────────────────────────
REDTHREAD_MONITOR_PROBE_INTERVAL=300   # Seconds between health checks
REDTHREAD_MONITOR_AUTO_CAMPAIGN=true   # Auto-trigger campaign on drift alert
REDTHREAD_MONITOR_COOLDOWN_PERIOD=1800 # Seconds before next auto-campaign

# ── LangSmith Observability (Phase 5D) ───────────────────────────────────────
# Targeted tracing: JudgeAgent + DefenseSynthesis only (Attacker muted)
REDTHREAD_LANGSMITH_ENABLED=false      # Set to true to enable LangSmith tracing
REDTHREAD_LANGSMITH_PROJECT=redthread  # LangSmith project name
REDTHREAD_LANGSMITH_API_KEY=ls-...your-key-here...

